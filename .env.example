# Leave unset to use the built-in multilingual fixtures.
WORDPRESS_API_URL=https://cms.cgic.be

# Server-only RecruitCRM credentials. Never prefix this token with NEXT_PUBLIC_.
RECRUITCRM_API_TOKEN=
RECRUITCRM_API_URL=https://api.recruitcrm.io

# Optional, invisible post-application sidecar. Leave unset by default.
# It runs only after RecruitCRM accepts the application and can never block the candidate flow.
TALENT_VAULT_API_URL=

# Local/preview only. Production intentionally shows no fixture jobs when RecruitCRM is not configured.
RECRUITCRM_USE_FIXTURES=false

# Shared HMAC secret used by WordPress to invalidate Next.js content caches.
WORDPRESS_WEBHOOK_SIGNING_SECRET=replace-with-a-random-secret

# Added during WordPress setup for exact-revision preview.
WORDPRESS_PREVIEW_USERNAME=
WORDPRESS_PREVIEW_APPLICATION_PASSWORD=
WORDPRESS_PREVIEW_SIGNING_SECRET=
